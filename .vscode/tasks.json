{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "compile",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "panel": "shared", "reveal": "silent" },
            "problemMatcher": "$tsc"
        },
        {
            "type": "npm",
            "script": "watch",
            "isBackground": true,
            "presentation": { "panel": "shared", "reveal": "never" },
            "problemMatcher": "$tsc-watch"
        },
        {
            "type": "npm",
            "script": "test",
            "group": "test",
            "presentation": { "panel": "shared", "reveal": "always" }
        }
    ]
}
