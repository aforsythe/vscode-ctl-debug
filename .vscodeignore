# Files NOT to ship inside the .vsix package.  Source, dev tooling,
# CI, tests, and docs that aren't relevant to runtime stay out.
.vscode/**
.vscode-test/**
.github/**
src/**
tests/**
docs/**
.gitignore
.eslintrc.js
.editorconfig
**/tsconfig.json
**/*.map
**/*.ts
CONTRIBUTING.md
scripts/**
# media/ images SHIP in the .vsix because the Marketplace renders
# README.md and needs to find them.  Only the dev-only README in
# media/ is excluded.
media/README.md
