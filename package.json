{
    "name": "ctl-debug",
    "displayName": "CTL Debug",
    "description": "Single-pixel debugger for CTL color transform language modules",
    "version": "0.1.0",
    "publisher": "ctl-org",
    "repository": {
        "type": "git",
        "url": "https://github.com/ampas/CTL"
    },
    "engines": { "vscode": "^1.80.0" },
    "categories": ["Debuggers", "Programming Languages"],
    "main": "./out/extension.js",
    "contributes": {
        "grammars": [{
            "language": "ctl",
            "scopeName": "source.ctl",
            "path": "./syntaxes/ctl.tmLanguage.json"
        }],
        "languages": [{
            "id": "ctl",
            "aliases": ["CTL", "Color Transform Language"],
            "extensions": [".ctl"]
        }],
        "debuggers": [{
            "type": "ctl",
            "label": "CTL Single-Pixel Debugger",
            "languages": ["ctl"],
            "configurationAttributes": {
                "launch": {
                    "required": ["program"],
                    "properties": {
                        "program": {
                            "type": "string",
                            "description": "Path to the .ctl file to debug",
                            "default": "${file}"
                        },
                        "programs": {
                            "type": "array",
                            "description": "Paths to .ctl files to chain (alternative to single `program`)",
                            "items": { "type": "string" }
                        },
                        "function": {
                            "type": "string",
                            "description": "CTL function to invoke",
                            "default": "main"
                        },
                        "functions": {
                            "type": "array",
                            "description": "Functions to invoke per stage (defaults to `main` for each)",
                            "items": { "type": "string" }
                        },
                        "modulePaths": {
                            "type": "array",
                            "description": "Additional directories to search for `import` statements (combined with $CTL_MODULE_PATH and per-file parent directories)",
                            "items": { "type": "string" }
                        },
                        "pixel": {
                            "type": "array",
                            "description": "Pixel value to drive the function on (3 or 4 floats)",
                            "items": { "type": "number" },
                            "default": [0.5, 0.5, 0.5]
                        },
                        "stopOnEntry": {
                            "type": "boolean",
                            "description": "Stop on the first executed instruction",
                            "default": false
                        },
                        "ctldap": {
                            "type": "string",
                            "description": "Path to the ctldap binary",
                            "default": "ctldap"
                        }
                    }
                }
            },
            "initialConfigurations": [
                {
                    "type": "ctl",
                    "request": "launch",
                    "name": "Debug CTL (single file)",
                    "program": "${file}",
                    "function": "main",
                    "pixel": [0.5, 0.5, 0.5],
                    "stopOnEntry": false
                },
                {
                    "type": "ctl",
                    "request": "launch",
                    "name": "Debug ACES chain (IDT → RRT → ODT)",
                    "programs": ["${workspaceFolder}/IDT.ctl", "${workspaceFolder}/RRT.ctl", "${workspaceFolder}/ODT.ctl"],
                    "functions": ["IDT::main", "RRT::main", "ODT::main"],
                    "pixel": [0.18, 0.18, 0.18],
                    "modulePaths": ["${workspaceFolder}/aces-dev/transforms/ctl/lib"],
                    "stopOnEntry": false
                }
            ]
        }]
    },
    "activationEvents": [
        "onDebug",
        "onLanguage:ctl"
    ],
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch":   "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node":    "^20.0.0",
        "@types/vscode":  "^1.80.0",
        "typescript":     "^5.0.0"
    }
}
